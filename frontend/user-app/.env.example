# Backend API URL
VITE_API_URL=http://localhost:5000

# OAuth Providers — set to true to show login button
# Credentials are handled by the backend (configured in appsettings.json)
# Only enable providers that are configured in the backend
VITE_OAUTH_GOOGLE_ENABLED=true
VITE_OAUTH_SPOTIFY_ENABLED=false
VITE_OAUTH_TWITCH_ENABLED=false
