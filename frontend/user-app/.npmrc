# Workaround for npm optional dependency bug with rollup Windows binaries
# When installing in environments that mix Windows/Linux (WSL, CI):
# 1. Run: npm pack @rollup/rollup-win32-x64-msvc@<rollup-version>
# 2. Extract: tar -xzf <tarball> -C node_modules/@rollup/rollup-win32-x64-msvc --strip-components=1
# 3. Delete tarball
#
# Or just run: npm install && npm pack @rollup/rollup-win32-x64-msvc@$(node -p "require('./node_modules/rollup/package.json').version") && ...

strict-ssl=false
